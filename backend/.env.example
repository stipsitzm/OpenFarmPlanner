# Example .env for OpenFarmPlanner Django backend
# Copy this file to backend/.env and adjust values for your deployment

DEBUG=False
DJANGO_ENV=development
SECRET_KEY=please_change_me_in_prod

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,example.com,www.example.com

# CORS and CSRF settings (comma-separated)
CORS_ALLOWED_ORIGINS=https://example.com,http://www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com,http://www.example.com

# Proxy / HTTPS settings for deployments behind a reverse proxy
SECURE_SSL_REDIRECT=True
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
USE_X_FORWARDED_HOST=True
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Database settings
DB_NAME=farmplanner_db
DB_USER=farmplanner
DB_PASSWORD=farmplanner
DB_HOST=localhost
DB_PORT=5432

# Optional backend prefix for legacy/subpath deployments
URL_PREFIX=openfarmplanner
