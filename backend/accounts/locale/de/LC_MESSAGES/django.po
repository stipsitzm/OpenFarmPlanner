#: accounts/serializers.py:79
msgid "An account with this email already exists."
msgstr "Ein Konto mit dieser E-Mail-Adresse existiert bereits."

#: accounts/serializers.py:84 accounts/serializers.py:125
msgid "Passwords do not match."
msgstr "Die Passwoerter stimmen nicht ueberein."

#: accounts/templates/accounts/emails/activation_email.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"please activate your OpenFarmPlanner account by clicking the link below:\n"
"\n"
"%(link)s\n"
"\n"
"If you did not create this account, you can ignore this email."
msgstr ""
"Hallo,\n"
"\n"
"bitte aktiviere deinen OpenFarmPlanner-Account über den folgenden Link:\n"
"\n"
"%(link)s\n"
"\n"
"Falls du dieses Konto nicht erstellt hast, kannst du diese E-Mail ignorieren."

#: accounts/templates/accounts/emails/password_reset_email.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"use the following link to reset your OpenFarmPlanner password:\n"
"\n"
"%(link)s\n"
"\n"
"If you did not request this reset, you can ignore this email."
msgstr ""
"Hallo,\n"
"\n"
"verwende den folgenden Link, um dein OpenFarmPlanner-Passwort "
"zurückzusetzen:\n"
"\n"
"%(link)s\n"
"\n"
"Falls du diese Zurücksetzung nicht angefragt hast, kannst du diese E-Mail "
"ignorieren."

#: accounts/views.py:39
msgid "If the account exists, an email has been sent."
msgstr "Falls das Konto existiert, wurde eine E-Mail gesendet."

#: accounts/views.py:58
msgid "Activate your OpenFarmPlanner account"
msgstr "OpenFarmPlanner-Konto aktivieren"

#: accounts/views.py:71
msgid "Reset your OpenFarmPlanner password"
msgstr "OpenFarmPlanner-Passwort zurücksetzen"

#: accounts/views.py:91
msgid "CSRF cookie set"
msgstr "CSRF-Cookie gesetzt"

#: accounts/views.py:102
msgid ""
"Registration successful. Please check your email to activate your account."
msgstr "Registrierung erfolgreich. Bitte pruefe deine E-Mails, um dein Konto zu aktivieren."

#: accounts/views.py:113
msgid "Invalid activation link."
msgstr "Ungueltiger Aktivierungslink."

#: accounts/views.py:118
msgid "Invalid or expired activation token."
msgstr "Ungueltiges oder abgelaufenes Aktivierungs-Token."

#: accounts/views.py:138
msgid "Invalid credentials."
msgstr "Ungueltige Zugangsdaten."

#: accounts/views.py:141
msgid "Account is not activated yet."
msgstr "Das Konto ist noch nicht aktiviert."

#: accounts/views.py:150
msgid "Logged out."
msgstr "Abgemeldet."

#: accounts/views.py:158
msgid "Authentication credentials were not provided."
msgstr "Authentifizierungsdaten wurden nicht bereitgestellt."

#: accounts/views.py:200 accounts/views.py:204
msgid "Invalid reset link."
msgstr "Ungueltiger Zuruecksetzungslink."

#: accounts/views.py:208
msgid "Invalid or expired reset token."
msgstr "Ungueltiges oder abgelaufenes Zuruecksetzungs-Token."

#: accounts/views.py:212
msgid "Password has been reset successfully."
msgstr "Das Passwort wurde erfolgreich zurueckgesetzt."
