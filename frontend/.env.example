VITE_ENABLE_AI=false

# VITE_API_BASE_URL: Override the Axios base URL for API requests.
#
# In development, leave this UNSET so all /api/* requests go through
# the Vite dev-server proxy (vite.config.ts → server.proxy), which
# forwards them to http://localhost:8000 server-side.
#
# Setting this to an absolute URL like http://localhost:8000/api causes
# the BROWSER to call that URL directly — bypassing the proxy.  This
# works on the same machine but breaks any access from other devices on
# the local network (phone, tablet) because "localhost" resolves to
# the device itself, not the development machine.
#
# Only set this if the backend runs under a non-standard path and you
# know what you're doing:
# VITE_API_BASE_URL=

# DEV_BACKEND_ORIGIN: Optional Vite dev-server proxy target.
# This is read by vite.config.ts on the development machine, not by the browser.
# Keep VITE_API_BASE_URL unset for LAN testing unless you need direct browser
# requests to the backend.
# DEV_BACKEND_ORIGIN=http://127.0.0.1:8000
